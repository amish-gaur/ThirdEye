# Copy to `.env` and fill in. `.env` is git-ignored.

# ---- Vision pipeline ----
NODE_ID=node_amish
# Vision POSTs JSON here. Same machine: localhost below. Remote/teammate use your ngrok URL:
# ACTION_ROUTER_URL=https://YOUR_SUBDOMAIN.ngrok-free.dev/event
ACTION_ROUTER_URL=http://127.0.0.1:8001/event
MOCK_CLASSIFIER=false

# ---- Anthropic (Step 3: AI narration) ----
ANTHROPIC_API_KEY=sk-ant-...
# Pick the latest model your account has access to. Update if Anthropic ships
# a newer Claude Sonnet/Haiku before demo day.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5

# ---- ElevenLabs (Step 3: TTS) ----
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # "Rachel"; pick any voice from your library
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5      # fast + low-latency
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ---- Twilio (Step 4: Outbound voice + MMS) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15555550100             # your provisioned SafeWatch number

# ---- Demo phones (NOT real 911 — the Emergency tier dials a teammate) ----
HOMEOWNER_PHONE=+15555550101
EMERGENCY_DISPATCH_PHONE=+15555550102        # teammate playing "911 Dispatcher"
FAMILY_PHONE=+15555550103

# ---- Service ----
HOST=0.0.0.0
PORT=8001

# Public URL Twilio will fetch the MP3 from. During demo: `ngrok http 8001`
# and paste the https URL here. For local dev, leave as http://127.0.0.1:8001
# (Twilio cannot reach localhost; calls will fail without a public URL).
PUBLIC_BASE_URL=http://127.0.0.1:8001
MEDIA_DIR=./media

# ---- Behavior knobs ----
# If true, route every tier to the dry-run logger (no real Twilio/ElevenLabs/Claude calls).
DRY_RUN=false

# If true, narrate with Claude. If false, use a static template (still works).
USE_CLAUDE=true

# If true, call with ElevenLabs <Play> (requires key + non-localhost PUBLIC_BASE_URL).
# If false, use Twilio <Say> only (reliable for demos without TTS setup).
USE_ELEVENLABS=false
